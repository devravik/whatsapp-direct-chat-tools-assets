{
  "id": "insta-mosaic-collage",
  "name": "Mosaic Collage",
  "description": "Artistic mosaic layout with overlapping images and creative spacing.",
  "minImages": 2,
  "maxImages": 8,
  "tools": [
    "instagram-post"
  ],
  "tags": [
    "instagram",
    "mosaic",
    "collage",
    "artistic",
    "multiple"
  ],
  "groups": [
    {
      "id": "container",
      "label": "Poster"
    },
    {
      "id": "mosaic",
      "label": "Images"
    },
    {
      "id": "banner",
      "label": "Banner"
    },
    {
      "id": "title",
      "label": "Title"
    },
    {
      "id": "brand",
      "label": "Brand"
    }
  ],
  "colorSets": [
    {
      "id": "crimson",
      "colors": [
        "#E74C3C",
        "#F87171",
        "#FEF2F2",
        "#7F1D1D"
      ]
    },
    {
      "id": "verdant",
      "colors": [
        "#25D366",
        "#4FF07F",
        "#ECFDF5",
        "#166534"
      ]
    },
    {
      "id": "aqua",
      "colors": [
        "#22D3EE",
        "#38BDF8",
        "#ECFEFF",
        "#0E7490"
      ]
    },
    {
      "id": "gold",
      "colors": [
        "#FACC15",
        "#F59E0B",
        "#FFFBEB",
        "#92400E"
      ]
    },
    {
      "id": "teal",
      "colors": [
        "#22D3EE",
        "#38BDF8",
        "#ECFEFF",
        "#0E7490"
      ]
    }
  ],
  "defaultColorSet": "crimson",
  "listingPreview": {
    "bgColor": "#1F2937",
    "accentColor": "#E74C3C",
    "textColor": "#F9FAFB",
    "label": "MOSAIC"
  },
  "content": {
    "type": "container",
    "key": "poster",
    "group": "container",
    "style": {
      "bg": {
        "value": "#ECF0F1",
        "editable": true,
        "key": "posterBg",
        "label": "Poster Background",
        "group": "container"
      },
      "bgImageUrl": "https://raw.githubusercontent.com/devravik/whatsapp-direct-chat-tools-assets/refs/heads/main/assets/template-engine/template-images/5338740_7132.jpg",
      "bgImageOpacity": 1.0,
      "bgImageFit": "cover",
      "justifyContent": "center",
      "overflow": "hidden"
    },
    "children": [
      {
        "type": "absolute-fill",
        "key": "overlay",
        "style": {
          "bg": {
            "colorSet": 1
          },
          "opacity": {
            "value": 0.3,
            "editable": true,
            "key": "bgOpacity",
            "label": "Overlay Opacity",
            "group": "container",
            "min": 0,
            "max": 1,
            "step": 0.05
          }
        }
      },
      {
        "type": "container",
        "key": "content",
        "style": {
          "flex": 1,
          "justifyContent": "space-between",
          "padding": {
            "value": 20,
            "editable": true,
            "key": "contentPadding",
            "label": "Content Padding",
            "group": "container",
            "min": 4,
            "max": 40,
            "step": 2
          }
        },
        "children": [
          {
            "type": "mosaic-grid",
            "key": "mosaicSection",
            "group": "mosaic",
            "style": {
              "gap": {
                "value": 12,
                "editable": true,
                "key": "mosaicGap",
                "label": "Image Gap",
                "group": "mosaic",
                "min": 0,
                "max": 24,
                "step": 2
              },
              "marginV": {
                "value": 10,
                "editable": true,
                "key": "mosaicMarginV",
                "label": "Image Section Margin",
                "group": "mosaic",
                "min": 0,
                "max": 24,
                "step": 2
              },
              "shadowColor": {
                "value": "#34495E",
                "editable": true,
                "key": "mosaicShadowColor",
                "label": "Image Shadow Color",
                "group": "mosaic"
              },
              "defaultBorderWidth": {
                "value": 3,
                "editable": true,
                "key": "mosaicImageBorderWidth",
                "label": "Image Border Width",
                "group": "mosaic",
                "min": 0,
                "max": 16,
                "step": 1
              },
              "defaultBorderColor": {
                "value": "#FFFFFF",
                "editable": true,
                "key": "mosaicImageBorderColor",
                "label": "Image Border Color",
                "group": "mosaic"
              },
              "defaultBorderRadius": {
                "value": 6,
                "editable": true,
                "key": "mosaicImageBorderRadius",
                "label": "Image Corner Radius",
                "group": "mosaic",
                "min": 0,
                "max": 36,
                "step": 2
              },
              "defaultShadowOpacity": {
                "value": 0.2,
                "editable": true,
                "key": "mosaicImageShadowOpacity",
                "label": "Image Shadow Opacity",
                "group": "mosaic",
                "min": 0,
                "max": 1,
                "step": 0.05
              },
              "defaultShadowRadius": {
                "value": 12,
                "editable": true,
                "key": "mosaicImageShadowRadius",
                "label": "Image Shadow Blur",
                "group": "mosaic",
                "min": 0,
                "max": 32,
                "step": 1
              },
              "defaultShadowOffsetX": {
                "value": 0,
                "editable": true,
                "key": "mosaicImageShadowOffsetX",
                "label": "Image Shadow Offset X",
                "group": "mosaic",
                "min": -24,
                "max": 24,
                "step": 1
              },
              "defaultShadowOffsetY": {
                "value": 6,
                "editable": true,
                "key": "mosaicImageShadowOffsetY",
                "label": "Image Shadow Offset Y",
                "group": "mosaic",
                "min": -24,
                "max": 24,
                "step": 1
              }
            }
          },
          {
            "type": "container",
            "key": "titleBanner",
            "group": "banner",
            "visible": {
              "anyOf": [
                "bannerLabel",
                "title"
              ]
            },
            "style": {
              "flexDirection": "row",
              "alignItems": "center",
              "bg": {
                "value": "#FFFFFF",
                "editable": true,
                "key": "bannerBg",
                "label": "Banner Background",
                "group": "banner"
              },
              "borderRadius": {
                "value": 6,
                "editable": true,
                "key": "bannerRadius",
                "label": "Banner Corner Radius",
                "group": "banner",
                "min": 0,
                "max": 32,
                "step": 2
              },
              "padding": {
                "value": 16,
                "editable": true,
                "key": "bannerPadding",
                "label": "Banner Padding",
                "group": "banner",
                "min": 4,
                "max": 32,
                "step": 2
              },
              "marginBottom": 12,
              "shadowColor": "#34495E",
              "shadow": "soft"
            },
            "children": [
              {
                "type": "text",
                "key": "title",
                "group": "title",
                "label": "Title",
                "defaultValue": "Highlights",
                "maxLength": 72,
                "defaults": {
                  "color": "#2C3E50",
                  "fontFamily": "PlayfairDisplay",
                  "sizeRelativeToWidth": 0.038,
                  "maxSizeRelativeToWidth": 0.08
                },
                "layoutRole": "bannerTitle",
                "adjustsFontSizeToFit": true,
                "minimumFontScale": 0.7,
                "numberOfLines": 2,
                "style": {
                  "fontWeight": "800",
                  "letterSpacing": -0.3,
                  "width": "100%",
                  "flexShrink": 1
                }
              }
            ]
          }
        ]
      }
    ]
  }
}